#!/usr/bin/env bash

cd "$HOME"

# -- Bat --
mkdir -p .config/bat
ln -sf ~/dotfiles/misc-configs/bat/config .config/bat/config

# -- Git Delta --
mkdir -p .config/git-delta
ln -sf ~/dotfiles/misc-configs/git-delta/themes.gitconfig .config/git-delta/themes.gitconfig

# -- Neovim --
mkdir -p .config/nvim
# -n: treat existing symlink to dir as file (ensures idempotent re-runs)
ln -sfn ~/dotfiles/lua .config/nvim/lua
ln -sf ~/dotfiles/init.lua .config/nvim/init.lua
ln -sf ~/dotfiles/lazy-lock.json .config/nvim/lazy-lock.json

# -- Ghostty --
mkdir -p .config/ghostty
ln -sf ~/dotfiles/misc-configs/ghostty/config.ghostty .config/ghostty/config

# -- Lazygit --
mkdir -p .config/lazygit
ln -sf ~/dotfiles/misc-configs/lazygit/config.yml .config/lazygit/config.yml

# -- Git --
ln -sf ~/dotfiles/gitignore_global .gitignore_global

# -- Claude Code --
mkdir -p .claude
ln -sf ~/dotfiles/misc-configs/claude/CLAUDE.md .claude/CLAUDE.md
# Linked individually (not the whole dir) to allow third-party skills alongside ours.
mkdir -p .claude/skills
ln -sfn ~/dotfiles/misc-configs/claude/skills/00-reminder .claude/skills/00-reminder
ln -sfn ~/dotfiles/misc-configs/claude/skills/01-commit-staged-dont-push .claude/skills/01-commit-staged-dont-push
ln -sfn ~/dotfiles/misc-configs/claude/skills/02-opinion-staged-changes .claude/skills/02-opinion-staged-changes
ln -sfn ~/dotfiles/misc-configs/claude/skills/03-familiarize-branch-changes .claude/skills/03-familiarize-branch-changes
ln -sfn ~/dotfiles/misc-configs/claude/skills/04-summarize-unresolved-pr-comments .claude/skills/04-summarize-unresolved-pr-comments
ln -sfn ~/dotfiles/misc-configs/claude/skills/05-create-branch-staged .claude/skills/05-create-branch-staged
ln -sfn ~/dotfiles/misc-configs/claude/skills/06-explain-code .claude/skills/06-explain-code
ln -sfn ~/dotfiles/misc-configs/claude/skills/07-guess-whats-next .claude/skills/07-guess-whats-next
# Status line
ln -sf ~/dotfiles/misc-configs/claude/statusline-command.sh .claude/statusline-command.sh
# Copied (not symlinked) because Claude Code modifies settings.json at runtime.
[[ -f .claude/settings.json ]] && cp .claude/settings.json ".claude/settings.$(date +%Y%m%d%H%M%S).json"
cp ~/dotfiles/misc-configs/claude/settings.json .claude/settings.json

# -- Starship --
ln -sf ~/dotfiles/misc-configs/starship/starship.toml .config/starship.toml

# -- Yazi --
mkdir -p .config/yazi
ln -sf ~/dotfiles/misc-configs/yazi/yazi.toml .config/yazi/yazi.toml

# -- Directories --
mkdir -p queue temp workspace

# -- Zsh --
if ! grep -q 'HAS_LOADED_CUSTOM_SCRIPTS' ~/.zshrc 2>/dev/null; then
  echo '
if [[ -z "$HAS_LOADED_CUSTOM_SCRIPTS" ]]; then
  export HAS_LOADED_CUSTOM_SCRIPTS=1

  source ~/dotfiles/zsh/env_vars.zsh
  source ~/dotfiles/zsh/functions.zsh
  source ~/dotfiles/zsh/aliases.zsh
fi
  ' >> ~/.zshrc
fi
